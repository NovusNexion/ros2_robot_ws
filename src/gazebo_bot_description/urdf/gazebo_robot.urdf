<?xml version="1.0"?>
<robot name="first_robot">
    <!-- ========== 全局材质 ========== -->
    <material name="white">
        <color rgba="1.0 1.0 1.0 0.3" />
    </material>
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0" />
    </material>
    <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0" />
    </material>
    <material name="red">
        <color rgba="1.0 0.0 0.0 1.0" />
    </material>
    <material name="green">
        <color rgba="0.0 1.0 0.0 1.0" />
    </material>
    <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0" />
    </material>

    <!-- ========== 基座 base_link ========== -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.06" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.12" radius="0.10" />
            </geometry>
            <material name="white" />
        </visual>
        <collision>
            <origin xyz="0 0 0.06" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.12" radius="0.10" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2" />
            <inertia ixx="0.00074" ixy="0.0" ixz="0.0"
                     iyy="0.00074" iyz="0.0"
                     izz="0.001" />
        </inertial>
    </link>

    <!-- ========== IMU（固定） ========== -->
    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.05 0.05 0.05" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.05 0.05 0.05" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.005" />
            <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
                     iyy="0.000001" iyz="0.0"
                     izz="0.000001" />
        </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link" />
        <child link="imu_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
    </joint>

    <!-- ========== 里程计（虚拟，固定于底盘中心） ========== -->
    <link name="odom_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
            <material name="gray" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.001" />
            <inertia ixx="0.0000001" ixy="0.0" ixz="0.0"
                     iyy="0.0000001" iyz="0.0"
                     izz="0.0000001" />
        </inertial>
    </link>

    <joint name="odom_joint" type="fixed">
        <parent link="base_link" />
        <child link="odom_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <!-- ========== 四个驱动轮（连续旋转关节，轴为 Y） ========== -->
    <!-- 宏定义轮子（可选，但此处直接展开） -->
    <!-- 前左轮 -->
    <link name="wheel_front_left">
        <visual>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" /> <!-- 圆柱轴线转为 Y -->
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.02" />
            <inertia ixx="0.000005" ixy="0.0" ixz="0.0"
                     iyy="0.000008" iyz="0.0"
                     izz="0.000005" />
        </inertial>
    </link>

    <joint name="wheel_fl_joint" type="continuous">
        <parent link="base_link" />
        <child link="wheel_front_left" />
        <origin xyz="0.08485 0.08485 0" rpy="0 0 0" /> <!-- d=0.12, angle=45° -->
        <axis xyz="0 1 0" />
    </joint>

    <!-- 前右轮 -->
    <link name="wheel_front_right">
        <visual>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.02" />
            <inertia ixx="0.000005" ixy="0.0" ixz="0.0"
                     iyy="0.000008" iyz="0.0"
                     izz="0.000005" />
        </inertial>
    </link>

    <joint name="wheel_fr_joint" type="continuous">
        <parent link="base_link" />
        <child link="wheel_front_right" />
        <origin xyz="0.08485 -0.08485 0" rpy="0 0 0" /> <!-- angle=-45° -->
        <axis xyz="0 1 0" />
    </joint>

    <!-- 后左轮 -->
    <link name="wheel_back_left">
        <visual>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.02" />
            <inertia ixx="0.000005" ixy="0.0" ixz="0.0"
                     iyy="0.000008" iyz="0.0"
                     izz="0.000005" />
        </inertial>
    </link>

    <joint name="wheel_bl_joint" type="continuous">
        <parent link="base_link" />
        <child link="wheel_back_left" />
        <origin xyz="-0.08485 0.08485 0" rpy="0 0 0" /> <!-- angle=135° -->
        <axis xyz="0 1 0" />
    </joint>

    <!-- 后右轮 -->
    <link name="wheel_back_right">
        <visual>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0 0 0.03" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.03" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.02" />
            <inertia ixx="0.000005" ixy="0.0" ixz="0.0"
                     iyy="0.000008" iyz="0.0"
                     izz="0.000005" />
        </inertial>
    </link>

    <joint name="wheel_br_joint" type="continuous">
        <parent link="base_link" />
        <child link="wheel_back_right" />
        <origin xyz="-0.08485 -0.08485 0" rpy="0 0 0" /> <!-- angle=-135° -->
        <axis xyz="0 1 0" />
    </joint>

    <!-- ========== 立柱（固定于底座顶部） ========== -->
    <link name="column_link">
        <visual>
            <origin xyz="0 0 0.1" rpy="0 0 0" /> <!-- 圆柱中心在关节上方0.1m -->
            <geometry>
                <cylinder length="0.2" radius="0.02" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0 0 0.1" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.2" radius="0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05" />
            <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
                     iyy="0.00001" iyz="0.0"
                     izz="0.00002" />
        </inertial>
    </link>

    <joint name="column_joint" type="fixed">
        <parent link="base_link" />
        <child link="column_link" />
        <origin xyz="0 0 0.12" rpy="0 0 0" /> <!-- 立柱底部在底座顶面 -->
    </joint>

    <!-- ========== 左手臂（肩关节绕 X 轴旋转） ========== -->
    <link name="left_arm_link">
        <visual>
            <origin xyz="0 -0.075 0" rpy="0 0 0" /> <!-- 向左延伸 -->
            <geometry>
                <box size="0.02 0.15 0.02" /> <!-- 长（Y方向）0.15 -->
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <origin xyz="0 -0.075 0" rpy="0 0 0" />
            <geometry>
                <box size="0.02 0.15 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.03" />
            <inertia ixx="0.000002" ixy="0.0" ixz="0.0"
                     iyy="0.000001" iyz="0.0"
                     izz="0.000002" />
        </inertial>
    </link>

    <joint name="left_shoulder_joint" type="revolute">
        <parent link="column_link" />
        <child link="left_arm_link" />
        <origin xyz="0 -0.05 0.1" rpy="0 0 0" /> <!-- 立柱顶部左侧 -->
        <axis xyz="1 0 0" /> <!-- 绕 X 轴摆动 -->
        <limit lower="-1.57" upper="1.57" effort="1.0" velocity="0.5" />
    </joint>

    <!-- 左手（固定于手臂末端） -->
    <link name="left_hand_link">
        <visual>
            <origin xyz="0 -0.02 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.015" />
            </geometry>
            <material name="green" />
        </visual>
        <collision>
            <origin xyz="0 -0.02 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.015" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01" />
            <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
                     iyy="0.000001" iyz="0.0"
                     izz="0.000001" />
        </inertial>
    </link>

    <joint name="left_hand_joint" type="fixed">
        <parent link="left_arm_link" />
        <child link="left_hand_link" />
        <origin xyz="0 -0.075 0" rpy="0 0 0" /> <!-- 手臂末端 -->
    </joint>

    <!-- ========== 右手臂（对称） ========== -->
    <link name="right_arm_link">
        <visual>
            <origin xyz="0 0.075 0" rpy="0 0 0" /> <!-- 向右延伸 -->
            <geometry>
                <box size="0.02 0.15 0.02" />
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <origin xyz="0 0.075 0" rpy="0 0 0" />
            <geometry>
                <box size="0.02 0.15 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.03" />
            <inertia ixx="0.000002" ixy="0.0" ixz="0.0"
                     iyy="0.000001" iyz="0.0"
                     izz="0.000002" />
        </inertial>
    </link>

    <joint name="right_shoulder_joint" type="revolute">
        <parent link="column_link" />
        <child link="right_arm_link" />
        <origin xyz="0 0.05 0.1" rpy="0 0 0" /> <!-- 立柱顶部右侧 -->
        <axis xyz="1 0 0" />
        <limit lower="-1.57" upper="1.57" effort="1.0" velocity="0.5" />
    </joint>

    <!-- 右手 -->
    <link name="right_hand_link">
        <visual>
            <origin xyz="0 0.02 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.015" />
            </geometry>
            <material name="green" />
        </visual>
        <collision>
            <origin xyz="0 0.02 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.015" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01" />
            <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
                     iyy="0.000001" iyz="0.0"
                     izz="0.000001" />
        </inertial>
    </link>

    <joint name="right_hand_joint" type="fixed">
        <parent link="right_arm_link" />
        <child link="right_hand_link" />
        <origin xyz="0 0.075 0" rpy="0 0 0" />
    </joint>

    <!-- ========== 雷达（固定于立柱顶部） ========== -->
    <link name="laser_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.04" />
            </geometry>
            <material name="gray" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.04" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01" />
            <inertia ixx="0.000002" ixy="0.0" ixz="0.0"
                     iyy="0.000002" iyz="0.0"
                     izz="0.000004" />
        </inertial>
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="column_link" />
        <child link="laser_link" />
        <origin xyz="0 0 0.2" rpy="0 0 0" /> <!-- 立柱顶端 -->
    </joint>

    <!-- ========== 摄像头（固定于立柱前侧） ========== -->
    <link name="camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.03 0.02 0.02" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.03 0.02 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01" />
            <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
                     iyy="0.000001" iyz="0.0"
                     izz="0.000001" />
        </inertial>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="column_link" />
        <child link="camera_link" />
        <origin xyz="0.06 0 0.15" rpy="0 1.57 0" /> <!-- 立柱前方，俯视 -->
    </joint>

</robot>
