<?xml version="1.0"?>
<robot name="first_robot">
    <!-- 全局材质定义 -->
     <material name="white">
        <color rgba="1.0 1.0 1.0 0.3" />   <!-- 不透明纯白 -->
    </material>
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0" />   <!-- 不透明纯黑 -->
    </material>

    <!-- 机器人本体 base_link -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.12" radius="0.10" />
            </geometry>
            <material name="white" />  <!-- 引用全局材质 -->
        </visual>
    </link>

    <!-- IMU 部件 imu_link -->
    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.05 0.05 0.05" />
            </geometry>
            <material name="black" />  <!-- 引用全局材质 -->
        </visual>
    </link>

    <!-- 固定关节 -->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link" />
        <child link="imu_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
    </joint>
</robot>
